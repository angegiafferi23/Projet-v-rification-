<!DOCTYPE html>
<html>
<head>
<title>Marketing Idea Generator</title>

<style>
body{
font-family: Arial;
text-align:center;
background:#f5f5f5;
padding-top:100px;
}

button{
padding:15px 25px;
font-size:18px;
border:none;
background:black;
color:white;
cursor:pointer;
}

#idea{
margin-top:30px;
font-size:22px;
font-weight:bold;
}
</style>
</head>

<body>

<h1>Marketing Idea Generator 🚀</h1>

<button onclick="generateIdea()">Generate Idea</button>

<p id="idea"></p>

<script>

const ideas = [
"Create a viral TikTok challenge for your brand",
"Partner with a niche influencer",
"Launch a limited edition product",
"Create a behind-the-scenes content series",
"Run a giveaway on Instagram",
"Use storytelling to present your product",
"Create a meme marketing campaign",
"Build a community on Discord"
]

function generateIdea(){

const random = ideas[Math.floor(Math.random()*ideas.length)]

document.getElementById("idea").innerText = random

}

</script>

</body>
</html>
